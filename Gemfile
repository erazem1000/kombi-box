source "https://rubygems.org"

# Webrick je potreben za Ruby 3+ (ni več v standardni knjižnici)
gem "webrick"

# GitHub Pages gem (zagotavlja kompatibilnost z GitHub Pages okoljem)
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end
